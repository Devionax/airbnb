<%- include("../partial/header")%>
<div class="container">
  <div class="floating floating-1"></div>
  <div class="floating floating-2"></div>

  <div class="main-wrapper">
    <!-- Left Side - Brand Section with Background -->
    <div class="left-side">
      <div class="left-content">
        <div class="brand-container">
          <h1 class="brand">Airbnb</h1>
          <div class="brand-subtitle">
            Become a <span class="highlight">Host</span>
          </div>
          <div class="brand-subtitle">
            Share Your Space • Earn Extra Income • Join Our Community
          </div>
        </div>

        <div class="host-quote">
          <div class="quote-text">
            "Hosting on Airbnb allowed me to turn my spare room into a steady
            income stream. The best decision I made last year!"
          </div>
          <div class="quote-author">- Sarah, Host since 2020</div>
        </div>
        <% if(enterUserData?.userRole === "host" ){ %> 
        <div class="inner_left_side">
          <a href="/host/add_home" class="btn-neu">
            <i class="fas fa-plus"></i> List Your Home
          </a>
        </div>
        <% } %>
      </div>
    </div>

    <!-- Right Side - Content Section -->
    <div class="right-side">
      <div class="neumorph-box">
        <div class="carousel-container">

          <div class="carousel">
            <div class="carousel-inner">
              <!-- This will be dynamically generated by EJS -->

              <%  topRatedHouses.forEach((topRated, index) => {
                const {Hid, Hname,
            Haddress, Hrooms, Hrating, Hprice, Hfloor, Himg }= topRated; %>
              <div class="carousel-item <%= index === 0 ? 'active' : '' %>">
                <img src="/uploads/<%= Himg %>" alt="<%= Himg %>" class="carousel-img">
                <div class="carousel-content">
                   <% for (let i = 0; i < Math.floor(Hrating); i++) { %>
                    <span class="star">★</span>
                    <% } %> <% if (Hrating % 1 !== 0) { %>
                    <span class="star">½</span>
                    <% } %>
                  <h2><%= Hname %></h2>
                  <p><%= Haddress %></p>
                </div>
              </div>
              <% }); %>
            </div>

            <button class="carousel-control prev">❮</button>
            <button class="carousel-control next">❯</button>
          </div>

          <div class="carousel-indicators">
            <% topRatedHouses.forEach((item, index) => { %>
            <div class="indicator <%= index === 0 ? 'active' : '' %>" data-index="<%= index %>"></div>
            <% }); %>
          </div>

          <div class="carousel-status">
            Slide <span id="current-slide">1</span> of <span id="total-slides"><%= topRatedHouses.length %></span>
          </div>
          <div class="progress-bar">
            <div class="progress" id="progress"></div>
          </div>
        </div>


        <div class="benefits">
          <div class="benefit-item">
            <div class="benefit-icon">
              <i class="fas fa-dollar-sign"></i>
            </div>
            <div class="benefit-text">Earn Extra Income</div>
          </div>

          <div class="benefit-item">
            <div class="benefit-icon">
              <i class="fas fa-calendar-alt"></i>
            </div>
            <div class="benefit-text">Flexible Schedule</div>
          </div>

          <div class="benefit-item">
            <div class="benefit-icon">
              <i class="fas fa-shield-alt"></i>
            </div>
            <div class="benefit-text">Host Protection</div>
          </div>

          <div class="benefit-item">
            <div class="benefit-icon">
              <i class="fas fa-globe-americas"></i>
            </div>
            <div class="benefit-text">Global Community</div>
          </div>
        </div>

        <div class="stats">
          <div class="stat-item">
            <div class="stat-number">4M+</div>
            <div class="stat-label">Hosts Worldwide</div>
          </div>

          <div class="stat-item">
            <div class="stat-number">$150B+</div>
            <div class="stat-label">Earned by Hosts</div>
          </div>

          <div class="stat-item">
            <div class="stat-number">191</div>
            <div class="stat-label">Countries & Regions</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
<script>
  document.addEventListener('DOMContentLoaded', function() {
    const carouselInner = document.querySelector('.carousel-inner');
    const carouselItems = document.querySelectorAll('.carousel-item');
    const prevButton = document.querySelector('.carousel-control.prev');
    const nextButton = document.querySelector('.carousel-control.next');
    const indicators = document.querySelectorAll('.indicator');
    const currentSlideElement = document.getElementById('current-slide');
    const totalSlidesElement = document.getElementById('total-slides');
    const progressBar = document.getElementById('progress');

    let currentIndex = 0;
    const totalItems = carouselItems.length;
    let autoSlideInterval;
    let progressInterval;
    const autoSlideDelay = 5000; // 5 seconds

    // Function to update carousel position
    function updateCarousel() {
      carouselInner.style.transform = `translateX(-${currentIndex * 100}%)`;

      // Update active class for items
      carouselItems.forEach((item, index) => {
        item.classList.toggle('active', index === currentIndex);
      });

      // Update indicators
      indicators.forEach((indicator, index) => {
        indicator.classList.toggle('active', index === currentIndex);
      });

      // Update current slide number
      currentSlideElement.textContent = currentIndex + 1;

      // Reset progress bar
      resetProgressBar();
    }

    // Next slide function
    function nextSlide() {
      currentIndex = (currentIndex + 1) % totalItems;
      updateCarousel();
      resetAutoSlide();
    }

    // Previous slide function
    function prevSlide() {
      currentIndex = (currentIndex - 1 + totalItems) % totalItems;
      updateCarousel();
      resetAutoSlide();
    }

    // Progress bar animation
    function startProgressBar() {
      let width = 0;
      progressBar.style.width = '0%';

      progressInterval = setInterval(() => {
        if (width >= 100) {
          clearInterval(progressInterval);
        } else {
          width += 1;
          progressBar.style.width = width + '%';
        }
      }, autoSlideDelay / 100);
    }

    function resetProgressBar() {
      clearInterval(progressInterval);
      startProgressBar();
    }

    // Auto slide function
    function startAutoSlide() {
      autoSlideInterval = setInterval(nextSlide, autoSlideDelay);
      startProgressBar();
    }

    function resetAutoSlide() {
      clearInterval(autoSlideInterval);
      clearInterval(progressInterval);
      startAutoSlide();
    }

    // Event listeners for buttons
    nextButton.addEventListener('click', nextSlide);
    prevButton.addEventListener('click', prevSlide);

    // Event listeners for indicators
    indicators.forEach(indicator => {
      indicator.addEventListener('click', function() {
        currentIndex = parseInt(this.getAttribute('data-index'));
        updateCarousel();
        resetAutoSlide();
      });
    });

    // Keyboard navigation
    document.addEventListener('keydown', function(e) {
      if (e.key === 'ArrowLeft') {
        prevSlide();
      } else if (e.key === 'ArrowRight') {
        nextSlide();
      }
    });

    // Initialize auto slide
    startAutoSlide();

    // Pause auto slide on hover
    const carousel = document.querySelector('.carousel');
    carousel.addEventListener('mouseenter', () => {
      clearInterval(autoSlideInterval);
      clearInterval(progressInterval);
      progressBar.style.animationPlayState = 'paused';
    });

    carousel.addEventListener('mouseleave', () => {
      startAutoSlide();
      progressBar.style.animationPlayState = 'running';
    });

    // Swipe support for touch devices
    let startX = 0;
    let endX = 0;

    carousel.addEventListener('touchstart', (e) => {
      startX = e.touches[0].clientX;
    });

    carousel.addEventListener('touchmove', (e) => {
      endX = e.touches[0].clientX;
    });

    carousel.addEventListener('touchend', () => {
      handleSwipe();
    });

    function handleSwipe() {
      const swipeThreshold = 50;

      if (startX - endX > swipeThreshold) {
        // Swipe left - next slide
        nextSlide();
      } else if (endX - startX > swipeThreshold) {
        // Swipe right - previous slide
        prevSlide();
      }
    }
  });
</script>
</body>

</html>