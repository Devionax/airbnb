<%- include("../partial/header") %>

<div class="page-background-centering-wrapper">
  <div class="main-content-container">
    <h1 class="page-title-heading">Register Your Home 🏡</h1>
    <form class="neumorphic-home-registration-form" action="/host/add_home" method="POST" autocomplete="on" enctype="multipart/form-data">
      <%  if (newHouseData) {
        var { Hname, Haddress, Hrooms, Hrating, Hprice, Hfloor } = newHouseData;
      } %>
      <!-- House Name (Left) -->
      <div class="input-group-container">
        <label for="firstName">House's Name</label>
        <input type="text" id="firstName" name="Hname" placeholder="Nuh house ..." value="<%= Hname ?Hname:'' %>" required />
      </div>

      <!-- Address (Right) -->
      <div class="input-group-container">
        <label for="email">House Address</label>
        <input type="text" id="email" name="Haddress" placeholder="Fsd ..." value="<%= Haddress ?Haddress:'' %>" required />
      </div>

      <!-- Rooms (Left) -->
      <div class="input-group-container">
        <label for="rooms">No. of Rooms</label>
        <input type="number" id="rooms" name="Hrooms" placeholder="1" min="1" value="<%= Hrooms?Hrooms:'' %>" required />
      </div>

      <!-- Floor (Right) -->
      <div class="input-group-container">
        <label for="floor">Floor</label>
        <input type="number" id="floor" name="Hfloor" value="<%= Hfloor ?Hfloor :'' %>" placeholder="1" min="1" value="1" required />
      </div>

      <!-- Price (Left) -->
      <div class="input-group-container">
        <label for="price">Price per Night ($)</label>
        <input type="number" id="price" name="Hprice" value="<%= Hprice?Hprice:'' %>" placeholder="100" min="0" step="0.01" value="100" required />
      </div>

      <!-- Rating (Right) -->
      <div class="input-group-container">
        <label for="rating">Rating (1-5 Stars)</label>
        <select id="rating" name="Hrating" required>
          <option value="5" <%= Hrating == 5 ? "selected" : "" %>>5 Stars</option>
          <option value="4" <%= Hrating == 4 ? "selected" : "" %>>4 Stars</option>
          <option value="3" <%= Hrating == 3 ? "selected" : "" %>>3 Stars</option>
          <option value="2" <%= Hrating == 2 ? "selected" : "" %>>2 Stars</option>
          <option value="1" <%= Hrating == 1 ? "selected" : "" %>>1 Star</option>
        </select>
      </div>

      <!-- File Upload (Spans full width) -->
      <div class="input-group-container" style="grid-column: 1 / -1;">
        <%if (multerError){   %>
        <p style="color: red;
    padding-left: 10px;">*<%= multerError%></p>
        <%}%>
          <label for="file">Room Picture</label>
          <input type="file" id="file" name="Himg" accept="image/*" required/>
        </div>

        <!-- Submit (Spans full width) -->
        <button class="submit-button-action" type="submit">➕ Add Home</button>
      </form>
    </div>
  </div>

  <script>
    // Mobile menu toggle functionality
    document.getElementById('mobileMenuBtn').addEventListener('click', function() {
      document.getElementById('mobileNav').classList.toggle('active');
    });

    // Close mobile menu when clicking outside
    document.addEventListener('click', function(event) {
      const mobileNav = document.getElementById('mobileNav');
      const mobileMenuBtn = document.getElementById('mobileMenuBtn');
      
      if (!mobileNav.contains(event.target) && !mobileMenuBtn.contains(event.target)) {
        mobileNav.classList.remove('active');
      }
    });
  </script>
</body>

</html>