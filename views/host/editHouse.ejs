<%- include("../partial/header") %>

<% 
  const { _id, Hname, Haddress, Hrooms, Hrating, Hprice, Hfloor, Himg } = foundHouseById ;
%>

<div class="page-background-centering-wrapper">
  <div class="main-content-container">
    <h1 class="page-title-heading">Edit Your Home 🏡</h1>

    <form 
      class="neumorphic-home-registration-form" 
      action="/host/editHome" 
      method="POST" 
      autocomplete="on" 
      enctype="multipart/form-data"
    >

      <!-- House Name -->
      <div class="input-group-container">
        <input type="hidden" name="_id" value="<%= _id %>">
        <label for="firstName">House's Name</label>
        <input type="text" id="firstName" name="Hname" value="<%= Hname %>" required />
      </div>

      <!-- Address -->
      <div class="input-group-container">
        <label for="email">House Address</label>
        <input type="text" id="email" name="Haddress" value="<%= Haddress %>" required />
      </div>

      <!-- Rooms -->
      <div class="input-group-container">
        <label for="rooms">No. of Rooms</label>
        <input type="number" id="rooms" name="Hrooms" min="1" value="<%= Hrooms %>" required />
      </div>

      <!-- Floor -->
      <div class="input-group-container">
        <label for="floor">Floor</label>
        <input type="number" id="floor" name="Hfloor" min="1" value="<%= Hfloor %>" required />
      </div>

      <!-- Price -->
      <div class="input-group-container">
        <label for="price">Price per Night ($)</label>
        <input 
          type="number" 
          id="price" 
          name="Hprice" 
          min="0" 
          step="0.01" 
          value="<%= Hprice %>" 
          required 
        />
      </div>

      <!-- Rating -->
      <div class="input-group-container">
        <label for="rating">Rating (1-5 Stars)</label>
        <select id="rating" name="Hrating" required>
          <option value="5" <%= Hrating == 5 ? "selected" : "" %>>5 Stars</option>
          <option value="4" <%= Hrating == 4 ? "selected" : "" %>>4 Stars</option>
          <option value="3" <%= Hrating == 3 ? "selected" : "" %>>3 Stars</option>
          <option value="2" <%= Hrating == 2 ? "selected" : "" %>>2 Stars</option>
          <option value="1" <%= Hrating == 1 ? "selected" : "" %>>1 Star</option>
        </select>
      </div>

      <!-- File Upload -->
      <div class="input-group-container image-field" style="grid-column: 1 / -1;">
         <%if (multerError){   %>
        <p style="color: red;
    padding-left: 10px;">*<%= multerError%></p>
        <%}%>

  <% if (Himg) { %>
    <img class="house-img-preview" src="/uploads/<%= Himg %>" alt="House image" />
  <% } %>

  <label for="file">Room Picture</label>
  <input type="file" id="file" name="Himg" accept="image/*"  />
</div>


      <button class="submit-button-action" type="submit">➕ Add Home</button>
    </form>
  </div>
</div>

<script>
  document.getElementById('mobileMenuBtn').addEventListener('click', function() {
    document.getElementById('mobileNav').classList.toggle('active');
  });

  document.addEventListener('click', function(event) {
    const mobileNav = document.getElementById('mobileNav');
    const mobileMenuBtn = document.getElementById('mobileMenuBtn');
    
    if (!mobileNav.contains(event.target) && !mobileMenuBtn.contains(event.target)) {
      mobileNav.classList.remove('active');
    }
  });
</script>

</body>
</html>
